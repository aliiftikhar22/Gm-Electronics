// Firestore Security Rules for GM Electronics
// Firebase Console → Firestore Database → Rules tab → paste this → Publish

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Products: anyone can read (so the website can show them),
    // only a signed-in admin can add/edit/delete.
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders: anyone can create an order (customers aren't logged in),
    // but only a signed-in admin can read, update or delete them.
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
